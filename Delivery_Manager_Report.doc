    <tr><td>name</td><td>VARCHAR(100)</td><td>Full name</td></tr>
    <tr><td>email</td><td>VARCHAR(150), UNIQUE</td><td>Email address</td></tr>
    <tr><td>password_hash</td><td>VARCHAR(255)</td><td>Bcrypt hashed password</td></tr>
    <tr><td>phone</td><td>VARCHAR(20)</td><td>Phone number</td></tr>
    <tr><td>role</td><td>ENUM</td><td>customer, seller, delivery_manager, admin</td></tr>
